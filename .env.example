# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_DATABASE=image_organizer

# 雪花算法配置
SNOWFLAKE_WORKER_ID=1
SNOWFLAKE_DATACENTER_ID=1

# 源目录配置
SOURCE_DIR=D:\Pictures\source

# 目标目录配置
TARGET_DIR=D:\Pictures\organized

# 分类规则配置 (使用正则表达式)
# 支持JavaScript正则表达式语法，不区分大小写匹配
# 示例：匹配以 IMG_ 开头的文件
CATEGORY_A_REGEX=^IMG_.*
# 示例：匹配包含日期格式的文件，如 20240115_photo.jpg
CATEGORY_B_REGEX=^\d{8}_.*

# 分类名称
CATEGORY_A_NAME=风景照片
CATEGORY_B_NAME=人物照片

# 默认分类（无法匹配时使用）
DEFAULT_CATEGORY=other
